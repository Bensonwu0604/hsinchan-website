# ══════════════════════════════════════════════════════════════════════════════
# .htaccess — 欣晨工業有限公司
# 安全強化 + 效能最佳化設定（Apache 2.4+）
# ══════════════════════════════════════════════════════════════════════════════

# ─── 1. HTTPS 強制轉向（啟用前請先確認 SSL 憑證已安裝） ──────────────────────
# <IfModule mod_rewrite.c>
#   RewriteEngine On
#   RewriteCond %{HTTPS} off
#   RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>

# ─── 2. HTTP 安全標頭 ────────────────────────────────────────────────────────
<IfModule mod_headers.c>

  # 防止點擊劫持（Clickjacking）— 禁止此網站被 iframe 嵌入
  Header always set X-Frame-Options "SAMEORIGIN"

  # 防止 MIME 類型嗅探（防止瀏覽器猜測錯誤的檔案類型）
  Header always set X-Content-Type-Options "nosniff"

  # 控制 Referrer 資訊（只在同來源時傳送完整 URL，跨站只傳送來源域名）
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # 限制瀏覽器功能權限（關閉不需要的 API 減少攻擊面）
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"

  # XSS 保護（舊版瀏覽器備援）
  Header always set X-XSS-Protection "1; mode=block"

  # HSTS — 強制 HTTPS（啟用 HTTPS 後再取消下方註解，max-age=31536000 = 1年）
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Content Security Policy（CSP）
  # 說明：
  #   default-src 'self'        → 預設只允許本站資源
  #   script-src 'self'         → JS 只允許本站（main.js）
  #   style-src  ... fonts.goog → CSS 允許本站 + Google Fonts
  #   font-src   fonts.gstatic  → 字型只來自 Google Fonts CDN
  #   img-src    'self' data:   → 圖片允許本站 + data URI（base64）
  #   connect-src 'self'        → fetch/XHR 只允許本站（content.json）
  #   frame-ancestors 'none'    → 強化版 X-Frame-Options（禁止任何 iframe 嵌入）
  #   object-src 'none'         → 禁止 Flash/ActiveX 等外掛
  #   base-uri 'self'           → 防止 base 標籤注入攻擊
  #   form-action 'self' mailto:→ 表單只能提交到本站或 mailto（聯絡表單用）
  Header always set Content-Security-Policy "\
    default-src 'self'; \
    script-src 'self'; \
    style-src 'self' https://fonts.googleapis.com; \
    font-src https://fonts.gstatic.com; \
    img-src 'self' data: https:; \
    connect-src 'self'; \
    frame-src 'none'; \
    frame-ancestors 'none'; \
    object-src 'none'; \
    base-uri 'self'; \
    form-action 'self' mailto:; \
    upgrade-insecure-requests"

  # 移除洩漏伺服器資訊的標頭
  Header always unset X-Powered-By
  Header always unset Server

</IfModule>

# ─── 3. 禁止目錄列舉（防止直接瀏覽 /photo/ 等目錄） ────────────────────────
Options -Indexes

# ─── 4. 保護敏感設定檔案（禁止直接存取） ─────────────────────────────────────
<FilesMatch "^(\.htaccess|\.htpasswd|\.env|\.git|content\.json|llms\.txt|sitemap\.xml|robots\.txt)$">
  # content.json / llms.txt / sitemap.xml 需要被瀏覽器/爬蟲讀取，故僅封鎖 .env 等
</FilesMatch>

<FilesMatch "\.(env|log|bak|sql|conf|ini|sh|py|rb|pl|cgi)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# ─── 5. 防止存取隱藏檔案與目錄（.git、.DS_Store 等） ────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule "(^|/)\.(?!well-known)" - [F,L]
</IfModule>

# ─── 6. 效能最佳化：啟用 Gzip 壓縮 ─────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json text/xml application/xml image/svg+xml
</IfModule>

# ─── 7. 效能最佳化：快取控制 ─────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — 短暫快取（內容常更新）
  ExpiresByType text/html                  "access plus 1 hour"

  # CSS / JS — 中期快取
  ExpiresByType text/css                   "access plus 1 month"
  ExpiresByType application/javascript     "access plus 1 month"
  ExpiresByType text/javascript            "access plus 1 month"

  # 圖片 — 長期快取
  ExpiresByType image/webp                 "access plus 1 year"
  ExpiresByType image/jpeg                 "access plus 1 year"
  ExpiresByType image/png                  "access plus 1 year"
  ExpiresByType image/svg+xml              "access plus 1 year"
  ExpiresByType image/gif                  "access plus 1 year"

  # 字型 — 長期快取（字型不常更換）
  ExpiresByType font/woff2                 "access plus 1 year"
  ExpiresByType font/woff                  "access plus 1 year"

  # JSON（content.json）— 短期快取
  ExpiresByType application/json           "access plus 1 hour"
</IfModule>

# ─── 8. 關閉 ETag（避免洩漏 inode 資訊） ────────────────────────────────────
FileETag None
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>

# ─── 9. 字元集強制 UTF-8 ─────────────────────────────────────────────────────
AddDefaultCharset UTF-8

# ─── 10. 錯誤頁面自訂（避免預設錯誤頁洩漏 Apache 版本） ───────────────────────
# ErrorDocument 404 /404.html
# ErrorDocument 403 /403.html
